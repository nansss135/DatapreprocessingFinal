      "source": [
        "from sklearn.impute import SimpleImputer\n",
        "num_imputer = SimpleImputer(strategy=\"mean\")\n",
        "merged_df[\"income_mean\"] = num_imputer.fit_transform(\n",
        "    merged_df[[\"income\"]])"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "7BcwDBW6KrMw"
      },
      "outputs": [],
      "source": [
        "median_imputer = SimpleImputer(strategy=\"median\")\n",
        "merged_df[\"income_median\"] = median_imputer.fit_transform(\n",
        "    merged_df[[\"income\"]])"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "GqgLOHBqKveX"
      },
      "outputs": [],
      "source": [
        "cat_imputer = SimpleImputer(\n",
        "    strategy=\"most_frequent\")\n",
        "merged_df[\"city_imputed\"] = cat_imputer.fit_transform(\n",
        "    merged_df[[\"city\"]]\n",
        ").ravel()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "zakxPs73K0ex"
      },
      "outputs": [],
      "source": [
        "merged_df[\"income_missing\"] = (\n",
        "    merged_df[\"income\"]\n",
        "    .isnull()\n",
        "    .astype(int))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "R2DiQH5lK5fc"
      },
      "outputs": [],
      "source": [
        "merged_df[\"income_random\"] = merged_df[\"income\"]\n",
        "\n",
        "random_sample = (\n",
        "    merged_df[\"income\"]\n",
        "    .dropna()\n",
        "    .sample(\n",
        "        merged_df[\"income\"].isnull().sum(),\n",
        "        random_state=42\n",
        "    )\n",
        ")\n",
        "\n",
        "random_sample.index = merged_df[\n",
        "    merged_df[\"income\"].isnull()\n",
        "].index\n",
        "\n",
        "merged_df.loc[\n",
        "    merged_df[\"income\"].isnull(),\n",
        "    \"income_random\"\n",
        "] = random_sample"
      ]
    },
