      "source": [
        "  lower = merged_df[\"income\"].quantile(0.01)\n",
        "\n",
        "upper = merged_df[\"income\"].quantile(0.99)\n",
        "\n",
        "percentile_df = merged_df[\n",
        "\n",
        "    (merged_df[\"income\"] >= lower)\n",
        "\n",
        "    &\n",
        "\n",
        "    (merged_df[\"income\"] <= upper)\n",
        "\n",
        "]\n",
        "\n",
        "percentile_df.head()"
      ]
    },
