      "source": [
        "from scipy.stats.mstats import winsorize\n",
        "\n",
        "merged_df[\"income_winsor\"] = winsorize(\n",
        "\n",
        "    merged_df[\"income\"],\n",
        "\n",
        "    limits=[0.01,0.01]\n",
        "\n",
        ")"
      ]
    },
