        "from sklearn.experimental import enable_iterative_imputer\n",
        "from sklearn.impute import IterativeImputer\n",
        "mice = IterativeImputer(\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "mice_result = mice.fit_transform(\n",
        "    merged_df[knn_columns]\n",
        ")\n",
        "\n",
        "mice_df = pd.DataFrame(\n",
        "\n",
        "    mice_result,\n",
        "\n",
        "    columns=knn_columns\n",
        "\n",
        ")\n",
        "mice_df.head()"
      ]
