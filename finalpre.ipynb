        "import sqlite3\n",
        "import pandas as pd\n",
        "with open('/content/products (1).sql', 'r') as f:\n",
        "    sql_script = f.read()\n",
        "conn = sqlite3.connect(':memory:')\n",
        "conn.executescript(sql_script)\n",
        "products = pd.read_sql(\"SELECT * FROM products\", conn)\n",
        "products.head()"
      ]
